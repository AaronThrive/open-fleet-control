{
  "name": "open-fleet-control",
  "version": "2.3.0",
  "description": "🦞 Open Fleet Control — AI agent fleet mission control. Spawn more Overlords!",
  "main": "lib/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node lib/server.js",
    "dev": "node --watch lib/server.js",
    "dev:src": "esbuild src/index.js --bundle --platform=node --outfile=lib/server.js --watch",
    "build": "esbuild src/index.js --bundle --platform=node --outfile=lib/server.js --banner:js='#!/usr/bin/env node' && prettier --write lib/server.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "test:e2e": "node tests-e2e/run.js",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint src/ tests/",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=true eslint src/ tests/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "echo 'Ready to spawn Overlords 🦞'"
  },
  "keywords": [
    "ai",
    "agent",
    "dashboard",
    "monitoring",
    "claude",
    "chatgpt",
    "llm",
    "command-center",
    "openclaw"
  ],
  "author": "OpenClaw Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronThrive/open-fleet-control.git"
  },
  "bugs": {
    "url": "https://github.com/AaronThrive/open-fleet-control/issues"
  },
  "homepage": "https://github.com/AaronThrive/open-fleet-control#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "eslint": "^8.56.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.2.4"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2"
  }
}
